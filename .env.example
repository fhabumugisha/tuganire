# Database
DATABASE_HOST=localhost:5432/tuganire
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Mail (Gmail SMTP example)
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@yourapp.com

# Stripe (Test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...

# App
BASE_URL=http://localhost:8080

# Proto.cx Voice API — native Kinyarwanda TTS (free Starter tier works).
# Get both values from the Proto dashboard: Settings → Workspace → Teamspaces.
# Leave blank to use the local MMS voice instead (automatic fallback).
PROTO_TTS_SUBCOMPANY_ID=        # "Teamspace ID"
PROTO_TTS_TOKEN=                # "Takeover secret"
PROTO_TTS_GENDER=female         # female | male

# AWS S3 (optional - only needed if using S3 storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

SENTRY_DSN=
